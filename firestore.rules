// ==========================================================
// Linkchain Firestore security rules
// Paste this into Firebase Console > Firestore Database > Rules
// ==========================================================
// Before this works: in Firebase Console > Authentication > Sign-in method,
// enable "Email/Password" (the app signs users in with a wallet-derived
// password against a synthetic address, so there's no real inbox involved).
// Then create a Firestore database (production mode) if you haven't already.
// ==========================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user's data lives under /users/{uid} and its subcollections:
    //   /users/{uid}                     -> profile doc { walletAddress }
    //   /users/{uid}/contacts/{id}        -> saved addresses
    //   /users/{uid}/transactions/{hash}  -> send history
    //   /users/{uid}/balances/{chainId}   -> latest per-chain balance
    //
    // A user can only read or write documents under their own uid.

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
